<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BoviCalc - Rationnement bovin intelligent</title>
  <link rel="stylesheet" href="./style.css">
  <link rel="icon" type="image/png" href="./Logo Bovicalc.png">
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>

<body>
<header class="rb-header">
  <div class="rb-header-inner">
    <div class="logo-box" onclick="backToHome()" style="cursor:pointer;">
      <img src="Logo Bovicalc.png" alt="BoviCalc Logo" class="logo">
    </div>
    <div class="title-box">
      <h1>BoviCalc</h1>
      <p>Optimisation des rations pour bovins</p>
    </div>
    <div class="header-actions">
<button onclick="backToHome()" class="hdr-btn">? Menu</button>
        <a href="index.html" class="hdr-btn hdr-btn-outline">?? Accueil</a>
    </div>
  </div>
  </header>
  <main class="rb-main">
    <!-- Accueil -->
    <section class="rb-section-grid" id="home-grid">
      <article class="rb-card" data-section="ration-a-z">
        <h2>?? Créer ma ration</h2>
        <p>De A à Z : besoins, ration, analyse et coûts</p>
        <button class="rb-btn rb-btn-primary">Commencer</button>
      </article>

      <article class="rb-card" data-section="besoins">
        <h2>?? Calculer mes besoins</h2>
        <p>Sans faire de ration complète</p>
        <button class="rb-btn">Ouvrir</button>
      </article>

      <article class="rb-card" data-section="ration-seule">
        <h2>?? Analyser ma ration</h2>
        <p>Apports seuls - sans besoins</p>
        <button class="rb-btn">Ouvrir</button>
      </article>

      <article class="rb-card" data-section="bilan-fourrager">
        <h2>?? Bilan fourrager</h2>
        <p>Stocks vs besoins du troupeau</p>
        <button class="rb-btn">Ouvrir</button>
      </article>
    </section>

    <!-- Ration A à Z - NOUVELLE VERSION ÉTAPES -->
    <section id="section-ration-a-z" class="rb-section-detail hidden">

      <!-- En-tête avec étapes de progression -->
      <div class="rb-section-header">
        <div class="wizard-header">
          <h2>?? Créer ma ration de A à Z</h2>
          <div class="wizard-steps">
            <div class="wizard-step active" data-step="1">
              <div class="step-number">1</div>
              <div class="step-label">Animal</div>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step" data-step="2">
              <div class="step-number">2</div>
              <div class="step-label">Ration</div>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step" data-step="3">
              <div class="step-number">3</div>
              <div class="step-label">Bilan</div>
            </div>
            <div class="wizard-connector"></div>
            <div class="wizard-step" data-step="4">
              <div class="step-number">4</div>
              <div class="step-label">Coûts</div>
            </div>
          </div>
        </div>
        <button class="rb-btn rb-btn-ghost" data-close>? Retour</button>
      </div>

      <!-- Étape 1 : Configuration Animal -->
      <div id="step-animal" class="wizard-step-content active">

        <div class="step-intro">
          <h3>Configuration de l'animal</h3>
          <p>Définissez les caractéristiques de l'animal pour calculer ses besoins nutritionnels.</p>
        </div>

        <form id="form-besoins-tab">
          <div class="rb-form-grid">
            <div class="rb-form-group">
              <label>Type d'animal <span class="required">*</span></label>
              <select id="type-animal" required>
                <option value="">Sélectionner</option>
                <optgroup label="Lait (UFL)">
                  <option value="vache-laitiere">Vache laitière</option>
                  <option value="vache-tarie">Vache tarie (0-4 sem.)</option>
                  <option value="vache-prepa-velage">Vache en prépa vêlage (4-8 sem.)</option>
                </optgroup>
                <optgroup label="Viande (UFV)">
                  <option value="genisse">Génisse (croissance)</option>
                  <option value="genisse-engrais">Génisse à engraisser</option>
                  <option value="vache-reforme">Vache réforme à engraisser</option>
                  <option value="veau">Veau</option>
                </optgroup>
              </select>
            </div>

            <div class="rb-form-group">
              <label>Race (optionnel)</label>
              <select id="race-animal">
                <option value="">Non spécifiée</option>
                <optgroup label="Laitières">
                  <option value="prim-holstein">Prim'Holstein</option>
                  <option value="montbeliarde">Montbéliarde</option>
                  <option value="normande">Normande</option>
                  <option value="jersiaise">Jersiaise</option>
                  <option value="brune">Brune</option>
                  <option value="pie-rouge">Pie Rouge</option>
                  <option value="tarentaise">Tarentaise</option>
                  <option value="simmental">Simmental</option>
                </optgroup>
                <optgroup label="Viandes">
                  <option value="charolaise">Charolaise</option>
                  <option value="limousine">Limousine</option>
                  <option value="blonde-aquitaine">Blonde d'Aquitaine</option>
                  <option value="salers">Salers</option>
                  <option value="aubrac">Aubrac</option>
                  <option value="gasconne">Gasconne</option>
                  <option value="herens">Hérens</option>
                </optgroup>
              </select>
            </div>

            <div class="rb-form-group">
              <label>Poids vif (kg) <span class="required">*</span></label>
              <input type="number" id="poids-vif" min="100" step="10" required placeholder="Ex: 650">
              <small class="form-hint">Poids approximatif de l'animal</small>
            </div>

            <div id="prod-group" class="rb-form-group">
              <label>Production laitière (kg/j)</label>
              <input type="number" id="production-lait" min="0" step="0.5" placeholder="Ex: 30">
            </div>

            <div id="gmq-group" class="rb-form-group" style="display:none;">
              <label>Objectif GMQ (kg/j)</label>
              <input type="number" id="gmq" min="0" max="2" step="0.1" placeholder="Ex: 1.0">
            </div>

            <div id="age-group" class="rb-form-group" style="display:none;">
              <label>Âge (mois)</label>
              <input type="number" id="age-mois" min="0" max="60" step="1" placeholder="Ex: 6">
            </div>

            <div class="rb-form-group">
              <label>Activité</label>
              <select id="activite">
                <option value="stabulation">Stabulation</option>
                <option value="paturage">Pâturage</option>
              </select>
            </div>

            <div id="tb-group" class="rb-form-group">
              <label>TB (g/L)</label>
              <input type="number" id="tb" min="20" step="0.5" placeholder="Ex: 38">
            </div>

            <div id="tp-group" class="rb-form-group">
              <label>TP (g/L)</label>
              <input type="number" id="tp" min="20" step="0.5" placeholder="Ex: 32">
            </div>
          </div>

          <div class="wizard-actions">
            <button type="button" id="btn-calc-besoins" class="rb-btn rb-btn-primary">
              Calculer les besoins ? étape 2
            </button>
            <button type="button" class="rb-btn rb-btn-ghost" onclick="backToHome()">? Accueil</button>
          </div>
        </form>

        <!-- Résultat des besoins -->
        <div id="resultat-besoins" class="rb-panel hidden result-panel">
          <h3>?? Besoins calculés</h3>
          <div id="resultat-besoins-content"></div>
          <div class="wizard-actions">
            <button type="button" class="rb-btn" onclick="goToStep(2)">
              Continuer vers la ration ?
            </button>
            <button type="button" class="rb-btn rb-btn-ghost" onclick="backToHome()">? Accueil</button>
          </div>
        </div>
      </div>

      <!-- Étape 2 : Construction de la ration -->
      <div id="step-ration" class="wizard-step-content">

        <div class="step-intro">
          <h3>Ma ration</h3>
          <p>Saisissez les aliments de votre ration en <strong>kg de Matière Sèche (MS)</strong>.</p>
        </div>

        <!-- Profils de ration -->
        <div class="rb-panel panel-profiles">
          <h4 style="margin-top:0;">?? Profils de ration</h4>
          <div class="rb-form-actions" style="gap:8px;flex-wrap:wrap;align-items:center;">
            <select id="ration-profiles" class="rb-select" style="min-width:200px;">
              <option value="">-- Sélectionner un profil --</option>
            </select>
            <button type="button" id="btn-save-ration-profile" class="rb-btn">Sauvegarder</button>
            <button type="button" id="btn-load-ration-profile" class="rb-btn">Charger</button>
            <button type="button" id="btn-delete-ration-profile" class="rb-btn" style="background:var(--danger);color:white;">Supprimer</button>
          </div>
        </div>

        <!-- Gestion des aliments personnalisés -->
        <div class="rb-panel panel-custom-foods">
          <h4 style="margin-top:0;">?? Gestion des aliments personnalisés</h4>
          <div class="rb-form-actions" style="gap:8px;flex-wrap:wrap;align-items:center;">
            <button type="button" id="btn-open-custom-modal-ration" class="rb-btn">+ Ajouter aliment</button>
            <select id="select-custom-aliment" class="rb-select" style="max-width:200px;">
              <option value="">Sélectionner...</option>
            </select>
            <button type="button" id="btn-edit-custom-aliment" class="rb-btn">??</button>
<button type="button" id="btn-delete-custom-aliment" class="rb-btn" style="background:var(--danger);color:white;">???</button>
          </div>
        </div>

        <!-- Liste des aliments de la ration -->
        <div class="rb-ration-lines">
          <div class="rb-ration-lines-head">
            <div>Aliment</div>
            <div>kg MS</div>
            <div></div>
          </div>
          <div id="ration-lines"></div>
          <div class="rb-form-actions" style="margin-top:16px;justify-content:flex-start;">
            <button type="button" id="btn-add-line" class="rb-btn">+ Ajouter un aliment</button>
            <button type="button" id="btn-calc-apports" class="rb-btn rb-btn-primary">Calculer les apports ? étape 3</button>
          </div>
        </div>

        <!-- Saisie rapide -->
        <details class="rb-details">
          <summary>Saisie rapide (texte)</summary>
          <div class="rb-help" style="margin-top:12px;">
            Format: <code> quantité aliment</code> (ex: <code>18 maïs</code> ou <code>6 ensilage herbe</code>)
            <br>Une ligne par aliment.
          </div>
          <textarea id="description-ration" rows="3" placeholder="18 maïs&#10;6 ensilage d'herbe"></textarea>
        </details>

        <!-- Résultats des apports -->
        <div id="resultat-apports" class="rb-panel hidden result-panel">
          <h3>?? Apports calculés</h3>
          <div id="resultat-apports-content"></div>
          <div class="wizard-actions">
            <button type="button" class="rb-btn" onclick="goToStep(1)">? Retour</button>
            <button type="button" class="rb-btn rb-btn-primary" onclick="goToStep(3)">
              Voir le bilan complet ?
            </button>
            <button type="button" class="rb-btn rb-btn-ghost" onclick="backToHome()">?? Accueil</button>
          </div>
        </div>
      </div>

      <!-- Étape 3 : Bilan nutritionnel -->
      <div id="step-bilan" class="wizard-step-content">
        <div class="step-intro">
          <h3>Bilan nutritionnel</h3>
          <p>Analyse complète des apports vs besoins. Ajoutez les minéraux pour calculer la balance anion-cation (BACA).</p>
        </div>

        <div class="rb-panel panel-minerals">
          <h4>?? Minéraux (optionnel — pour la BACA)</h4>
          <p style="font-size:.85rem;color:var(--text-light);margin-bottom:12px;">BACA = (Na + K + Ca + Mg) - (Cl + S) en mEq/kg MS. Idéal : -100 à +100 mEq/kg MS.</p>
          <div class="rb-form-grid">
            <div class="rb-form-group"><label>Na (g/kg MS)</label><input type="number" id="mineraux-na" min="0" step="0.1" placeholder="0"></div>
            <div class="rb-form-group"><label>K (g/kg MS)</label><input type="number" id="mineraux-k" min="0" step="0.1" placeholder="0"></div>
            <div class="rb-form-group"><label>Ca (g/kg MS)</label><input type="number" id="mineraux-ca" min="0" step="0.1" placeholder="0"></div>
            <div class="rb-form-group"><label>Mg (g/kg MS)</label><input type="number" id="mineraux-mg" min="0" step="0.1" placeholder="0"></div>
            <div class="rb-form-group"><label>Cl (g/kg MS)</label><input type="number" id="mineraux-cl" min="0" step="0.1" placeholder="0"></div>
            <div class="rb-form-group"><label>S (g/kg MS)</label><input type="number" id="mineraux-s" min="0" step="0.1" placeholder="0"></div>
          </div>
        </div>

        <div class="wizard-actions">
          <button type="button" class="rb-btn rb-btn-ghost" onclick="goToStep(2)">? Retour</button>
          <button type="button" id="btn-calc-bilan" class="rb-btn rb-btn-primary">?? Calculer le bilan</button>
          <button type="button" id="btn-ia-ration" class="rb-btn">?? Analyse IA</button>
          <button type="button" id="btn-export-pdf" class="rb-btn">?? PDF</button>
          <button type="button" id="btn-goto-costs" class="rb-btn rb-btn-secondary">?? Coûts ?</button>
        </div>

        <div id="resultat-bilan" class="rb-panel hidden result-panel">
          <h3>?? Bilan nutritionnel</h3>
          <div id="resultat-bilan-content"></div>
        </div>

        <div id="resultat-ia" class="rb-panel hidden result-panel">
          <h3>?? Analyse IA</h3>
          <div id="resultat-ia-contenu" style="white-space:pre-wrap;"></div>
        </div>
      </div>

      <!-- Étape 4 : Coûts -->
      <div id="step-cout" class="wizard-step-content">

        <div class="step-intro">
          <h3>Estimation des coûts</h3>
          <p>Calculez le coût de votre ration en fonction des prix de vos aliments.</p>
        </div>

        <div class="rb-help">
          <strong>Comment faire :</strong><br>
          1. Cliquez sur "Charger ma ration" pour récupérer les aliments de l'étape 2.<br>
          2. Saisissez le prix (€/tonne de MS) pour chaque aliment.<br>
          3. Indiquez les paramètres de votre troupeau.<br>
          4. Cliquez sur "Calculer le coût".
        </div>

        <div class="rb-panel" style="margin-top:24px;">
          <h3 style="margin-top:0;">1) Charger la ration</h3>
          <div class="rb-form-actions">
            <button type="button" id="btn-cout-charger-ration" class="rb-btn rb-btn-primary">
              ?? Charger ma ration
            </button>
          </div>

          <div id="cout-prix-ration" class="hidden" style="margin-top:20px;">
            <div class="rb-help">
              Renseignez les prix pour chaque aliment. Le calcul se fait automatiquement.
            </div>
            <div class="rb-ration-lines">
              <div class="rb-ration-lines-head" style="grid-template-columns: 1fr 120px 200px;">
                <div>Aliment</div>
                <div style="text-align:right;">kg MS</div>
                <div style="text-align:right;">Prix (€/t MS)</div>
              </div>
              <div id="cout-price-lines"></div>
            </div>
          </div>
        </div>

        <div class="rb-panel" style="margin-top:24px;">
          <h3 style="margin-top:0;">2) Paramètres troupeau</h3>
          <div class="rb-form-grid">
            <div class="rb-form-group">
              <label>Nombre de VL</label>
              <input type="number" id="cout-nb-vl" min="1" value="50" placeholder="Ex: 50">
            </div>
            <div class="rb-form-group">
              <label>Production annuelle (L/an)</label>
              <input type="number" id="cout-ref-lait" min="0" value="9000" placeholder="Ex: 9000">
            </div>
            <div class="rb-form-group">
              <label>Durée de la ration (jours)</label>
              <input type="number" id="cout-duree" min="1" value="180" placeholder="Ex: 180">
            </div>
            <div class="rb-form-group" id="cout-gmq-group">
              <label>GMQ (kg/jour) - viande</label>
              <input type="number" id="cout-gmq" min="0.1" step="0.1" value="1.0" placeholder="Ex: 1.0">
            </div>
          </div>
        </div>

        <div class="wizard-actions">
          <button type="button" class="rb-btn" onclick="goToStep(3)">? Bilan</button>
          <button type="button" id="btn-calc-cout" class="rb-btn rb-btn-primary">?? Calculer le coût</button>
          <button type="button" id="btn-export-cout-pdf" class="rb-btn">?? Exporter PDF</button>
        </div>

        <!-- Résultats des coûts -->
        <div id="cout-resultats" class="cost-result hidden" style="margin-top:32px;">
          <div class="rb-metric" id="metric-cout-vl" style="border-left:4px solid var(--primary);">
            <div class="rb-metric-head"><div class="rb-metric-title">Coût / VL / jour</div></div>
            <div class="rb-progress"><span style="width:80%"></span></div>
            <div class="rb-metric-sub" id="cout-vl-jour" style="font-size:1.4rem;font-weight:bold;color:var(--primary);margin-top:8px;">—</div>
          </div>
          <div class="rb-metric" id="metric-cout-1000l" style="border-left:4px solid var(--secondary);">
            <div class="rb-metric-head"><div class="rb-metric-title">Coût / 1000 L</div></div>
            <div class="rb-metric-sub" id="cout-1000l" style="font-size:1.4rem;font-weight:bold;color:var(--secondary);margin-top:8px;">—</div>
          </div>
          <div class="rb-metric" id="metric-cout-ms" style="border-left:4px solid var(--accent);">
            <div class="rb-metric-head"><div class="rb-metric-title">Coût / kg MS</div></div>
            <div class="rb-metric-sub" id="cout-kg-ms" style="font-size:1.4rem;font-weight:bold;color:var(--accent);margin-top:8px;">—</div>
          </div>
          <div class="rb-metric" id="metric-ms-vl" style="border-left:4px solid var(--success);">
            <div class="rb-metric-head"><div class="rb-metric-title">MS / VL / jour</div></div>
            <div class="rb-metric-sub" id="cout-ms-vl" style="font-size:1.4rem;font-weight:bold;color:var(--success);margin-top:8px;">—</div>
          </div>
        </div>

        <!-- Détail coûts -->
        <div id="cout-detail" class="rb-panel hidden" style="margin-top:24px;">
          <h3>?? Détail du coût par aliment</h3>
          <table class="rb-table" id="cout-table">
            <thead><tr><th>Aliment</th><th>kg MS</th><th>€/t MS</th><th>Coût (€)</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>

        <!-- Export coût -->
        <div id="cout-export-section" class="hidden" style="margin-top:24px;text-align:center;">
          <button id="btn-export-cout-pdf-2" class="rb-btn">?? Exporter le coût en PDF</button>
        </div>

      </div>

    <!-- Ration seule -->
    <section id="section-ration-seule" class="rb-section-detail hidden">
      <div class="rb-section-header">
        <h2>?? Ma ration</h2>
        <button class="rb-btn rb-btn-ghost" data-close>? Retour</button>
      </div>
      <div class="rb-help">Saisis tes aliments en kg MS</div>
      <div class="rb-ration-lines">
        <div class="rb-ration-lines-head"><div>Aliment</div><div>kg MS</div><div></div></div>
        <div id="ration-only-lines"></div>
        <div class="rb-form-actions" style="margin-top:12px;">
          <button type="button" id="btn-add-line-ration-only" class="rb-btn">+ Ligne</button>
          <button type="button" id="btn-calc-ration-only" class="rb-btn rb-btn-primary">Calculer</button>
          <button type="button" id="btn-export-ration-seule-pdf" class="rb-btn">?? Exporter PDF</button>
        </div>
        <datalist id="aliments-list-ration-only"></datalist>
      </div>
      <div id="resultat-ration-only" class="rb-panel hidden"></div>
    </section>

    <!-- Bilan fourrager AMÉLIORÉ -->
    <section id="section-bilan-fourrager" class="rb-section-detail hidden">
      <div class="rb-section-header">
        <h2>?? Bilan fourrager</h2>
        <button class="rb-btn rb-btn-ghost" data-close>? Retour</button>
      </div>

      <!-- Onglets pour le bilan fourrager -->
      <div class="rb-tabs" id="bf-tabs">
        <button class="rb-tab active" data-tab="bf-stocks">1. Stocks</button>
        <button class="rb-tab" data-tab="bf-troupeau">2. Troupeau</button>
        <button class="rb-tab" data-tab="bf-resultat">3. Résultat</button>
      </div>

      <!-- Onglet 1: Stocks -->
      <div id="tab-bf-stocks" class="rb-tab-content active">
        <div class="rb-help">
          Saisis tes <strong>stocks de fourrages</strong> en tonnes brutes et leur % de MS.
        </div>
        <div class="rb-ration-lines">
          <div class="rb-ration-lines-head" style="grid-template-columns: 1fr 140px 120px 50px;">
            <div>Fourrage</div>
            <div>t brut</div>
            <div>MS %</div>
            <div></div>
          </div>
          <div id="stock-lines"></div>
          <div class="rb-form-actions" style="margin-top:12px;">
            <button type="button" id="btn-add-stock" class="rb-btn">+ Ajouter un stock</button>
          </div>
        </div>
      </div>

      <!-- Onglet 2: Troupeau -->
      <div id="tab-bf-troupeau" class="rb-tab-content">
        <div class="rb-help">
          Configure les <strong>besoins du troupeau</strong> pour la période.
        </div>
        <!-- Profils de troupeau -->
        <div class="rb-panel" style="margin-top:12px;">
          <h4 style="margin-top:0;">?? Profils de troupeau</h4>
          <div class="rb-form-actions" style="gap:8px;flex-wrap:wrap;align-items:center;">
            <select id="herd-profiles" class="rb-select" style="min-width:200px;">
              <option value="">-- Sélectionner un profil --</option>
            </select>
            <button type="button" id="btn-save-herd-profile" class="rb-btn">Sauvegarder</button>
            <button type="button" id="btn-load-herd-profile" class="rb-btn">Charger</button>
            <button type="button" id="btn-delete-herd-profile" class="rb-btn" style="background:var(--error);color:white;">Supprimer</button>
          </div>
        </div>
        <div class="rb-form-grid">
          <div class="rb-form-group">
            <label>Nombre de VL</label>
            <input type="number" id="bf-nb-vaches" min="1" placeholder="Ex: 50">
          </div>
          <div class="rb-form-group">
            <label>Période (jours)</label>
            <input type="number" id="bf-duree" min="1" placeholder="Ex: 90">
          </div>
          <div class="rb-form-group">
            <label>MS / VL / jour (kg)</label>
            <input type="number" id="bf-ms-j" min="0" step="0.1" placeholder="Ex: 18">
          </div>
        </div>
      </div>

      <!-- Onglet 3: Résultat -->
      <div id="tab-bf-resultat" class="rb-tab-content">
        <div class="rb-form-actions">
          <button type="button" id="btn-calc-bilan-fourrager" class="rb-btn rb-btn-primary">?? Calculer le bilan</button>
          <button type="button" id="btn-export-bf-pdf" class="rb-btn">?? Exporter PDF</button>
        </div>

        <!-- Résultat visuel -->
        <div id="resultat-bilan-fourrager" class="hidden" style="margin-top:24px;">
          <div class="bf-visual">
            <div class="bf-visual-title">?? Visualisation</div>
            <div class="bf-silo-container">
              <div style="text-align:center;">
                <div class="bf-silo" style="height:120px;">
                  <div class="bf-silo-fill positive" id="bf-silo-stock" style="height:100%;"></div>
                  <div class="bf-silo-pct" id="bf-silo-stock-pct">100%</div>
                  <div class="bf-silo-label">Stock</div>
                </div>
              </div>
              <div class="bf-silo-arrow">?</div>
              <div style="text-align:center;">
                <div class="bf-silo" style="height:120px;">
                  <div class="bf-silo-fill" id="bf-silo-besoin" style="height:100%;"></div>
                  <div class="bf-silo-pct">100%</div>
                  <div class="bf-silo-label">Besoins</div>
                </div>
              </div>
            </div>
            <div class="bf-cow-row" id="bf-cow-row"></div>
            <div class="bf-status-msg positive" id="bf-status-msg">? Stocks suffisants !</div>
          </div>

        <div class="bf-summary">
          <div class="bf-card" id="bf-card-stock">
            <div class="bf-card-value" id="bf-stock-total">—</div>
            <div class="bf-card-label">Stock total (t MS)</div>
          </div>
          <div class="bf-card" id="bf-card-besoin">
            <div class="bf-card-value" id="bf-besoin-total">—</div>
            <div class="bf-card-label">Besoin total (t MS)</div>
          </div>
          <div class="bf-card" id="bf-card-bilan">
            <div class="bf-card-value" id="bf-bilan-value">—</div>
            <div class="bf-card-label">Solde (t MS)</div>
          </div>
        </div>
        <div id="bf-detail" class="rb-panel"></div>
      </div>

      <!-- Onglet 4: Calcul TMS -->
      <div id="tab-bf-calcul-tms" class="rb-tab-content">
        <div class="rb-help">
          <strong>Calcul de la TMS (Tonnes de Matière Sèche) d'un silo</strong><br><br>
          Pour calculer la TMS d'un silo, saisis les dimensions et les caractéristiques du fourrage.<br>
          Le calcul se fait automatiquement : <strong>TMS = Volume × Densité × (%MS/100) / 1000</strong>
        </div>

        <div class="rb-panel">
          <h4>?? Calculateur TMS</h4>
          <div class="rb-form-grid">
            <div class="rb-form-group">
              <label>Type de silo</label>
              <select id="tms-type-silo">
                <option value="tower">Silo tour (circulaire)</option>
                <option value="bunker">Silo bunker (rectangulaire)</option>
                <option value="couloir">Silo couloir</option>
                <option value="round">Ballon round</option>
              </select>
            </div>
            <div class="rb-form-group">
              <label>Longueur (m)</label>
              <input type="number" id="tms-longueur" min="0" step="0.1" placeholder="Ex: 20">
            </div>
            <div class="rb-form-group">
              <label>Largeur (m)</label>
              <input type="number" id="tms-largeur" min="0" step="0.1" placeholder="Ex: 4">
            </div>
            <div class="rb-form-group">
              <label>Hauteur (m)</label>
              <input type="number" id="tms-hauteur" min="0" step="0.1" placeholder="Ex: 2.5">
            </div>
            <div class="rb-form-group">
              <label>Diamètre (m) - si silo tour</label>
              <input type="number" id="tms-diametre" min="0" step="0.1" placeholder="Ex: 6">
            </div>
          </div>
          <div class="rb-form-grid">
            <div class="rb-form-group">
              <label>Type de fourrage</label>
              <select id="tms-fourrage">
                <option value="mais">Ensilage maïs</option>
                <option value="herbe">Ensilageherbe</option>
                <option value="enrub">Enrubannage</option>
                <option value="foin">Foin</option>
                <option value="paille">Paille</option>
              </select>
            </div>
            <div class="rb-form-group">
              <label>Ou densité estimée (kg/m³)</label>
              <input type="number" id="tms-densite" min="0" placeholder="Laisser vide pour valeur par défaut">
            </div>
            <div class="rb-form-group">
              <label>% MS du fourrage</label>
              <input type="number" id="tms-pourcent-ms" min="0" max="100" step="0.1" placeholder="Ex: 33">
            </div>
          </div>
          <div class="rb-form-actions">
            <button type="button" id="btn-calc-tms" class="rb-btn rb-btn-primary">Calculer la TMS</button>
            <button type="button" id="btn-add-tms-to-stock" class="rb-btn">+ Ajouter aux stocks</button>
          </div>
          <div id="resultat-tms" class="rb-panel hidden" style="margin-top:16px;"></div>
        </div>

        <div class="rb-panel" style="margin-top:20px;">
          <h4>?? Densités moyennes (kg/m³)</h4>
          <table style="width:100%;">
            <thead><tr><th>Fourrage</th><th>Densité</th><th>% MS typique</th></tr></thead>
            <tbody>
              <tr><td>Ensilage maïs</td><td>650-750 kg/m³</td><td>30-35%</td></tr>
              <tr><td>Ensilage herbes</td><td>550-650 kg/m³</td><td>25-35%</td></tr>
              <tr><td>Enrubannage</td><td>400-500 kg/m³</td><td>40-50%</td></tr>
              <tr><td>Foin</td><td>100-150 kg/m³</td><td>85-90%</td></tr>
              <tr><td>Paille</td><td>80-120 kg/m³</td><td>85-90%</td></tr>
            </tbody>
          </table>
        </div>

        <div class="rb-panel" style="margin-top:20px;">
          <h4>?? Formules</h4>
          <p><strong>Silo tour:</strong> Volume = ? × r² × hauteur (m³)</p>
          <p><strong>Silo bunker:</strong> Volume = longueur × largeur × hauteur (m³)</p>
          <p><strong>TMS:</strong> Volume (m³) × densité (kg/m³) × (%MS/100) / 1000 = TMS</p>
        </div>
      </div>
    </section>
  </main>

  <!-- ====== MODAL ALIMENT PERSONNALISÉ ====== -->
  <div id="custom-modal" class="rb-modal hidden">
    <div class="rb-modal-card" style="max-width:640px;">
      <div class="rb-modal-header">
        <h3>?? Ajouter un aliment</h3>
        <span class="rb-modal-close" data-modal-close>&times;</span>
      </div>
      <div class="rb-form-grid">
        <div class="rb-form-group" style="grid-column:1/-1;">
          <label>Nom de l'aliment *</label>
          <input type="text" id="custom-nom" placeholder="Ex: Ensilage maïs maison">
        </div>
        <div class="rb-form-group">
          <label>% MS *</label>
          <input type="number" id="custom-ms" min="1" max="100" step="0.1" placeholder="Ex: 35">
        </div>
        <div class="rb-form-group">
          <label>UFL / kg MS *</label>
          <input type="number" id="custom-ufl" min="0" step="0.01" placeholder="Ex: 0.90">
        </div>
        <div class="rb-form-group">
          <label>PDI g / kg MS *</label>
          <input type="number" id="custom-pdi" min="0" step="0.1" placeholder="Ex: 65">
        </div>
      </div>
      <details class="rb-details" style="margin-top:12px;">
        <summary>Minéraux (optionnel — pour la BACA)</summary>
        <div style="padding:16px;">
          <div class="rb-form-grid">
            <div class="rb-form-group"><label>Na g/kg MS</label><input type="number" id="custom-na" min="0" step="0.1"></div>
            <div class="rb-form-group"><label>K g/kg MS</label><input type="number" id="custom-k" min="0" step="0.1"></div>
            <div class="rb-form-group"><label>Ca g/kg MS</label><input type="number" id="custom-ca" min="0" step="0.1"></div>
            <div class="rb-form-group"><label>Mg g/kg MS</label><input type="number" id="custom-mg" min="0" step="0.1"></div>
            <div class="rb-form-group"><label>Cl g/kg MS</label><input type="number" id="custom-cl" min="0" step="0.1"></div>
            <div class="rb-form-group"><label>S g/kg MS</label><input type="number" id="custom-s" min="0" step="0.1"></div>
          </div>
          <div class="rb-panel" style="margin-top:8px;text-align:center;">
            BACA calculée : <strong id="custom-baca-value" style="color:var(--primary);">-</strong> mEq/kg MS
          </div>
        </div>
      </details>
      <div class="rb-form-actions" style="margin-top:20px;">
        <button type="button" class="rb-btn rb-btn-ghost" data-modal-close>Annuler</button>
        <button type="button" id="btn-add-custom" class="rb-btn rb-btn-primary">Ajouter</button>
      </div>
    </div>
  </div>

  <footer class="rb-footer">
    <p>© 2026 - BoviCalc | Outil pour les élevages</p>
  </footer>

  <script>
    console.log('Script 1 loaded');
    // Base d'aliments embarquée (fonctionne en local file://)
    window.RB_ALIMENTS_CSV = `Nom,MS,UFL INRA 2018 par kg,PDI INRA 2018 g/kg
Avoine,87.6,0.87,64.0
