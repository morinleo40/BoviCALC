  <script>
    // =====================================================
    // BOVICALC — Script principal (version clean)
    // =====================================================
    let alimentsDb = [];
    let customFoodsDb = [];
    let lastB = null;
    let lastA = null;
    let currentStep = 1;
    let costsByFeed = {};
    let editingFoodIndex = -1;

    const LS = {
      costs:          'bovicalc-costs',
      rationProfiles: 'bovicalc-ration-profiles',
      customFoods:    'bovicalc-custom-foods',
      herdProfiles:   'bovicalc-herd-profiles'
    };

    function saveLS(k, d) { try { localStorage.setItem(k, JSON.stringify(d)); } catch(e) {} }
    function loadLS(k, def) { try { const v = localStorage.getItem(k); return v ? JSON.parse(v) : def; } catch(e) { return def; } }
    function getNum(id) { const v = parseFloat(document.getElementById(id)?.value); return isFinite(v) ? v : 0; }
    function $(id) { return document.getElementById(id); }

    // -- Parsing CSV --------------------------------------
    function parseCsvLine(line) {
      const r = []; let cur = '', q = false;
      for (const c of line) {
        if (c === '"') q = !q;
        else if (c === ',' && !q) { r.push(cur); cur = ''; }
        else cur += c;
      }
      r.push(cur); return r;
    }
    function parseAlimentsCsv(csv) {
      if (!csv) return [];
      const lines = csv.trim().split('\n');
      const result = [];
      for (let i = 1; i < lines.length; i++) {
        const c = parseCsvLine(lines[i]);
        const nom = c[0]?.replace(/"/g,'').trim();
        const ms = parseFloat(c[1]) || 0;
        const uflBrut = parseFloat(c[2]) || 0;
        const pdiBrut = parseFloat(c[4]) || 0; // c[3] = MAT%
        if (!nom || !ms) continue;
        result.push({ nom, ms, uflPerKgMS: uflBrut / (ms/100), pdiPerKgMS: pdiBrut / (ms/100) });
      }
      return result;
    }

    // -- Hydrate datalists --------------------------------
    function hydrate() {
      const all = [...customFoodsDb, ...alimentsDb];
      ['aliments-list','aliments-list-ration-only'].forEach(id => {
        const el = $(id);
        if (el) el.innerHTML = all.map(a => `<option value="${a.nom}">`).join('');
      });
      refreshCustomSelect();
    }
    function refreshCustomSelect() {
      const sel = $('select-custom-aliment');
      if (!sel) return;
      sel.innerHTML = '<option value="">Sélectionner...</option>';
      customFoodsDb.forEach((a,i) => sel.innerHTML += `<option value="${i}">${a.nom}</option>`);
    }

    // -- Navigation principale ----------------------------
    const homeGrid = $('home-grid');
    const sectionIds = ['ration-a-z','ration-seule','bilan-fourrager'];

    function showSection(id) {
      homeGrid?.classList.add('hidden');
      sectionIds.forEach(sid => {
        const el = $('section-'+sid);
        if (el) el.classList.toggle('hidden', sid !== id);
      });
      window.scrollTo(0,0);
    }
    function backToHome() {
      homeGrid?.classList.remove('hidden');
      sectionIds.forEach(sid => $('section-'+sid)?.classList.add('hidden'));
    }
    document.querySelectorAll('[data-section]').forEach(card => {
      card.addEventListener('click', () => {
        let sid = card.dataset.section;
        if (sid === 'besoins') sid = 'ration-a-z';
        showSection(sid);
      });
    });
    document.querySelectorAll('[data-close]').forEach(btn => btn.addEventListener('click', backToHome));

    // -- Tabs ---------------------------------------------
    document.querySelectorAll('.rb-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const section = tab.closest('.rb-section-detail') || tab.closest('section');
        if (!section) return;
        section.querySelectorAll('.rb-tab').forEach(t => t.classList.remove('active'));
        section.querySelectorAll('.rb-tab-content').forEach(c => c.classList.remove('active'));
        tab.classList.add('active');
        $('tab-'+tab.dataset.tab)?.classList.add('active');
      });
    });

    // -- Wizard -------------------------------------------
    const stepMap = { 1:'animal', 2:'ration', 3:'bilan', 4:'cout' };
    function goToStep(n) {
      document.querySelectorAll('.wizard-step-content').forEach(el => el.classList.remove('active'));
      $('step-'+stepMap[n])?.classList.add('active');
      document.querySelectorAll('.wizard-step').forEach((el,i) => {
        el.classList.remove('active','completed');
        if (i+1 === n) el.classList.add('active');
        else if (i+1 < n) el.classList.add('completed');
      });
      currentStep = n;
      $('section-ration-a-z')?.scrollIntoView({behavior:'smooth',block:'start'});
    }

    // -- Animal type fields --------------------------------
    $('type-animal')?.addEventListener('change', function() {
      const v = this.value;
      const lait = ['vache-laitiere','vache-tarie','vache-prepa-velage'];
      const via  = ['genisse','genisse-engrais','vache-reforme','veau'];
      $('prod-group') && ($('prod-group').style.display = lait.includes(v) ? '' : 'none');
      $('tb-group')   && ($('tb-group').style.display   = lait.includes(v) ? '' : 'none');
      $('tp-group')   && ($('tp-group').style.display   = lait.includes(v) ? '' : 'none');
      $('gmq-group')  && ($('gmq-group').style.display  = via.includes(v)  ? '' : 'none');
      $('age-group')  && ($('age-group').style.display  = via.includes(v)  ? '' : 'none');
    });

    // -- Calcul besoins -----------------------------------
    function computeBesoins(pv, prod, activite, tb, tp, type, gmq) {
      const pv075 = Math.pow(pv, 0.75);
      const coef  = activite === 'paturage' ? 1.1 : 1;
      let bUFL=0, bPDI=0, lait=0, cap=0;
      switch(type) {
        case 'vache-laitiere':
          bUFL = (1.4 + 0.006*pv + prod*0.44)*coef;
          lait = prod*((tb||40)/40);
          bPDI = (95 + 0.5*pv + lait*48)*coef;
          cap  = (0.025*pv + 0.1*prod)*coef; break;
        case 'vache-tarie':
          bUFL = (0.054*pv075 + 2.5)*coef;
          bPDI = (95 + 0.5*pv + 150)*coef;
          cap  = pv*0.018*coef; break;
        case 'vache-prepa-velage':
          bUFL = (0.054*pv075 + 1.5)*coef;
          bPDI = (95 + 0.5*pv + 180)*coef;
          cap  = pv*0.02*coef; break;
        case 'genisse': case 'genisse-engrais': {
          const g = gmq||0.7;
          bUFL = (0.041*pv075 + 4.5*g)*coef;
          bPDI = (2.5*pv075 + 330*g)*coef;
          cap  = pv*0.025*coef; break; }
        case 'vache-reforme': {
          const g = gmq||0.8;
          bUFL = (0.041*pv075 + 4.5*g)*coef;
          bPDI = (2.5*pv075 + 330*g)*coef;
          cap  = pv*0.022*coef; break; }
        case 'veau': {
          const g = gmq||1.2;
          bUFL = (0.03*pv075 + 3.5*g)*coef;
          bPDI = (1.8*pv075 + 280*g)*coef;
          cap  = pv*0.03*coef; break; }
        default:
          bUFL = (0.054*pv075 + 3)*coef;
          bPDI = (95 + 0.5*pv + 200)*coef;
          cap  = pv*0.02*coef;
      }
      return { bUFL, bPDI, laitStandard:lait, ingestionCapacite:cap, typeLabel:type };
    }

    function calcBesoins() {
      const type = $('type-animal')?.value;
      const pv   = getNum('poids-vif');
      if (!type || !pv) { alert('Sélectionnez le type d\'animal et renseignez le poids vif.'); return; }
      lastB = computeBesoins(pv, getNum('production-lait'), $('activite')?.value||'stabulation',
                             getNum('tb'), getNum('tp'), type, getNum('gmq'));
      lastB.typeLabel = type;
      const c = $('resultat-besoins-content');
      if (c) c.innerHTML = `
        <div class="rb-metric-grid">
          <div class="rb-metric">
            <div class="rb-metric-head"><div class="rb-metric-title">Énergie (UFL/j)</div></div>
            <div style="font-size:1.6rem;font-weight:800;color:var(--primary);margin-top:8px;">${lastB.bUFL.toFixed(2)}</div>
          </div>
          <div class="rb-metric">
            <div class="rb-metric-head"><div class="rb-metric-title">PDI (g/j)</div></div>
            <div style="font-size:1.6rem;font-weight:800;color:var(--primary);margin-top:8px;">${lastB.bPDI.toFixed(0)} g</div>
          </div>
          ${lastB.ingestionCapacite > 0 ? `<div class="rb-metric">
            <div class="rb-metric-head"><div class="rb-metric-title">Capacité d'ingestion</div></div>
            <div style="font-size:1.6rem;font-weight:800;color:var(--primary);margin-top:8px;">${lastB.ingestionCapacite.toFixed(1)} kg MS/j</div>
          </div>` : ''}
        </div>`;
      $('resultat-besoins')?.classList.remove('hidden');
    }
    $('btn-calc-besoins')?.addEventListener('click', calcBesoins);

    // -- Ration lines -------------------------------------
    function addLine(containerId, listId) {
      const div = $(containerId); if (!div) return;
      const row = document.createElement('div');
      row.className = 'rb-ration-row';
      row.innerHTML = `
        <input list="${listId}" placeholder="Aliment..." autocomplete="off">
        <input type="number" placeholder="kg MS" step="0.1" min="0">
        <button type="button" onclick="this.closest('.rb-ration-row').remove()"
          style="background:var(--danger);color:#fff;border:none;border-radius:var(--r-sm);cursor:pointer;padding:6px 10px;font-weight:bold;">?</button>`;
      div.appendChild(row);
    }
    $('btn-add-line')?.addEventListener('click', () => addLine('ration-lines','aliments-list'));
    $('btn-add-line-ration-only')?.addEventListener('click', () => addLine('ration-only-lines','aliments-list-ration-only'));

    // -- Parse ration -------------------------------------
    function findFood(nom) {
      const k = nom.toLowerCase().trim();
      return [...customFoodsDb,...alimentsDb].find(a =>
        a.nom.toLowerCase() === k || a.nom.toLowerCase().includes(k) || k.includes(a.nom.toLowerCase())
      );
    }
    function parseRation(containerId) {
      const items = [];
      document.querySelectorAll('#'+containerId+' .rb-ration-row').forEach(row => {
        const inp = row.querySelectorAll('input');
        const nom = inp[0]?.value?.trim();
        const qty = parseFloat(inp[1]?.value);
        if (!nom || !qty || qty <= 0) return;
        const f = findFood(nom);
        if (f) items.push({ nom:f.nom, qty, ufl:f.uflPerKgMS*qty, pdi:f.pdiPerKgMS*qty });
      });
      return {
        items,
        totalMS:  items.reduce((s,i)=>s+i.qty,0),
        totalUFL: items.reduce((s,i)=>s+i.ufl,0),
        totalPDI: items.reduce((s,i)=>s+i.pdi,0)
      };
    }

    // -- Calcul apports -----------------------------------
    function calcApports() {
      const a = parseRation('ration-lines'); lastA = a;
      const c = $('resultat-apports-content');
      if (c) c.innerHTML = `
        <div class="rb-metric-grid">
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">MS totale</div></div>
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalMS.toFixed(1)} kg</div></div>
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">Énergie (UFL)</div></div>
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalUFL.toFixed(2)}</div></div>
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">PDI (g)</div></div>
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalPDI.toFixed(0)}</div></div>
        </div>`;
      $('resultat-apports')?.classList.remove('hidden');
    }
    $('btn-calc-apports')?.addEventListener('click', calcApports);

    // -- Calcul bilan -------------------------------------
    function calcBilan() {
      if (!lastB) { alert('Calculez d\'abord les besoins (étape 1).'); return; }
      if (!lastA || !lastA.items.length) calcApports();
      const a=lastA, b=lastB;
      const rUFL = b.bUFL>0 ? a.totalUFL/b.bUFL : 0;
      const rPDI = b.bPDI>0 ? a.totalPDI/b.bPDI : 0;
      const ppu  = a.totalUFL>0 ? a.totalPDI/a.totalUFL : 0;
      const eu   = ['genisse','genisse-engrais','vache-reforme','veau'].includes(b.typeLabel) ? 'UFV' : 'UFL';
      const badgeCls = r => r>=0.9&&r<=1.1?'rb-badge-green':r<0.9?'rb-badge-red':'rb-badge-orange';
      const badgeLbl = r => r>=0.9&&r<=1.1?'OK':r<0.9?'Deficit':'Exces';
      const barCls   = r => r>=0.9&&r<=1.1?'ok':r<0.9?'low':'high';
      const cont = $('resultat-bilan-content');
      if (!cont) return;
      cont.innerHTML = `
        <div class="rb-metric-grid">
          <div class="rb-metric">
            <div class="rb-metric-head">
              <div class="rb-metric-title">Energie (${eu})</div>
              <span class="rb-badge ${badgeCls(rUFL)}">${badgeLbl(rUFL)}</span>
            </div>
            <div class="rb-progress ${barCls(rUFL)}"><span style="width:${Math.min(100,rUFL*100)}%"></span></div>
            <div style="margin-top:8px;font-size:.9rem;">Apport <b>${a.totalUFL.toFixed(2)}</b> / Besoin <b>${b.bUFL.toFixed(2)}</b> = <b>${(rUFL*100).toFixed(0)}%</b></div>
          </div>
          <div class="rb-metric">
            <div class="rb-metric-head">
              <div class="rb-metric-title">PDI (g)</div>
              <span class="rb-badge ${badgeCls(rPDI)}">${badgeLbl(rPDI)}</span>
            </div>
            <div class="rb-progress ${barCls(rPDI)}"><span style="width:${Math.min(100,rPDI*100)}%"></span></div>
            <div style="margin-top:8px;font-size:.9rem;">Apport <b>${a.totalPDI.toFixed(0)}</b> / Besoin <b>${b.bPDI.toFixed(0)}</b> = <b>${(rPDI*100).toFixed(0)}%</b></div>
          </div>
          <div class="rb-metric">
            <div class="rb-metric-head">
              <div class="rb-metric-title">PDI / ${eu}</div>
              <span class="rb-badge ${ppu>=90&&ppu<=105?'rb-badge-green':'rb-badge-orange'}">${ppu>=90&&ppu<=105?'Ideal':'A ajuster'}</span>
            </div>
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary);margin-top:8px;">${ppu.toFixed(0)} g/${eu}</div>
            <div style="font-size:.8rem;color:var(--text-light);">Cible : 90-105 g/${eu}</div>
          </div>
          <div class="rb-metric">
            <div class="rb-metric-head"><div class="rb-metric-title">MS totale</div></div>
            <div style="font-size:1.4rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalMS.toFixed(1)} kg</div>
            ${b.ingestionCapacite>0?`<div style="font-size:.8rem;color:var(--text-light);">Capacite : ${b.ingestionCapacite.toFixed(1)} kg MS</div>`:''}
          </div>
        </div>
        <div class="rb-panel" style="margin-top:16px;">
          <h4>Composition de la ration</h4>
          <table class="rb-table">
            <thead><tr><th>Aliment</th><th>kg MS</th><th>${eu}</th><th>PDI (g)</th></tr></thead>
            <tbody>
              ${a.items.map(i=>`<tr><td>${i.nom}</td><td>${i.qty.toFixed(1)}</td><td>${i.ufl.toFixed(3)}</td><td>${i.pdi.toFixed(0)}</td></tr>`).join('')}
              <tr style="font-weight:700;background:var(--bg);"><td>TOTAL</td><td>${a.totalMS.toFixed(1)}</td><td>${a.totalUFL.toFixed(2)}</td><td>${a.totalPDI.toFixed(0)}</td></tr>
            </tbody>
          </table>
        </div>`;
      const na=getNum('mineraux-na'),k=getNum('mineraux-k'),ca=getNum('mineraux-ca');
      const mg=getNum('mineraux-mg'),cl=getNum('mineraux-cl'),s=getNum('mineraux-s');
      if(na||k||ca||mg||cl||s){
        const baca=(na*43.5+k*25.6+ca*49.9+mg*82.2)-(cl*28.2+s*62.4);
        cont.innerHTML+=`<div class="rb-panel" style="margin-top:16px;">
          <h4>Balance Anion-Cation (BACA)</h4>
          <div style="font-size:1.8rem;font-weight:800;color:${Math.abs(baca)<=100?'var(--primary)':'var(--danger)'};margin:8px 0;">${baca.toFixed(1)} mEq/kg MS</div>
          <div style="font-size:.85rem;color:var(--text-light);">Ideal : -100 a +100 mEq/kg MS</div>
        </div>`;
      }
      $('resultat-bilan')?.classList.remove('hidden');
    }
    $('btn-calc-bilan')?.addEventListener('click', calcBilan);
    $('btn-goto-costs')?.addEventListener('click', () => { if(!lastA){alert('Calculez d\'abord le bilan.');return;} goToStep(4); });

    // -- Couts --------------------------------------------
    $('btn-cout-charger-ration')?.addEventListener('click', () => {
      if (!lastA?.items?.length) { alert('Calculez d\'abord une ration (etapes 1 et 2).'); return; }
      const div = $('cout-price-lines'); if (!div) return;
      div.innerHTML = '';
      lastA.items.forEach(item => {
        const row = document.createElement('div');
        row.className = 'rb-ration-row';
        row.style.gridTemplateColumns = '1fr 100px 170px';
        row.innerHTML = `
          <div style="display:flex;align-items:center;font-weight:500;">${item.nom}</div>
          <div style="display:flex;align-items:center;justify-content:flex-end;">${item.qty.toFixed(1)} kg</div>
          <input type="number" class="cout-price-input" data-nom="${item.nom}"
                 placeholder="euro/t MS" value="${costsByFeed[item.nom]||''}" min="0" step="1" style="text-align:right;">`;
        div.appendChild(row);
      });
      $('cout-prix-ration')?.classList.remove('hidden');
    });

    $('btn-calc-cout')?.addEventListener('click', () => {
      if (!lastA?.items?.length) { alert('Chargez d\'abord la ration.'); return; }
      let totalCost=0, totalMS=0;
      document.querySelectorAll('.cout-price-input').forEach(inp => { costsByFeed[inp.dataset.nom]=parseFloat(inp.value)||0; });
      saveLS(LS.costs, costsByFeed);
      lastA.items.forEach(item => { totalCost+=item.qty*(costsByFeed[item.nom]||0)/1000; totalMS+=item.qty; });
      const laitJour = (parseFloat($('cout-ref-lait')?.value)||9000)/365;
      const setText = (id,txt) => { if ($(id)) $(id).textContent=txt; };
      setText('cout-vl-jour', totalCost.toFixed(2)+' euro');
      setText('cout-1000l', laitJour>0?((totalCost/laitJour)*1000).toFixed(2)+' euro':'---');
      setText('cout-kg-ms', totalMS>0?((totalCost/totalMS)*1000).toFixed(2)+' euro/t':'---');
      setText('cout-ms-vl', totalMS.toFixed(1)+' kg');
      $('cout-resultats')?.classList.remove('hidden');
      const tbody = document.querySelector('#cout-table tbody');
      if (tbody) tbody.innerHTML = lastA.items.map(i=>{
        const p=costsByFeed[i.nom]||0;
        return `<tr><td>${i.nom}</td><td>${i.qty.toFixed(1)}</td><td>${p.toFixed(0)}</td><td>${(i.qty*p/1000).toFixed(2)}</td></tr>`;
      }).join('') + `<tr style="font-weight:700;background:var(--bg);"><td>TOTAL</td><td>${totalMS.toFixed(1)}</td><td>---</td><td>${totalCost.toFixed(2)}</td></tr>`;
      $('cout-detail')?.classList.remove('hidden');
    });

    // -- Ration seule -------------------------------------
    $('btn-calc-ration-only')?.addEventListener('click', () => {
      const a = parseRation('ration-only-lines');
      const cont = $('resultat-ration-only'); if (!cont) return;
      if (!a.items.length) {
        cont.innerHTML = '<p style="color:var(--danger);padding:16px;">Aucun aliment reconnu. Verifiez les noms dans la base.</p>';
        cont.classList.remove('hidden'); return;
      }
      const ppu = a.totalUFL>0 ? a.totalPDI/a.totalUFL : 0;
      const rc  = ppu>=90&&ppu<=105?'ok':ppu<90?'low':'high';
      cont.innerHTML = `
        <h3>Resultats - Apports</h3>
        <div class="rb-metric-grid">
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">MS totale</div></div>
            <div style="font-size:1.5rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalMS.toFixed(1)} kg</div></div>
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">Energie (UFL)</div></div>
            <div style="font-size:1.5rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalUFL.toFixed(2)}</div></div>
          <div class="rb-metric"><div class="rb-metric-head"><div class="rb-metric-title">PDI (g)</div></div>
            <div style="font-size:1.5rem;font-weight:800;color:var(--primary);margin-top:8px;">${a.totalPDI.toFixed(0)}</div></div>
          <div class="rb-metric">
            <div class="rb-metric-head">
              <div class="rb-metric-title">PDI / UFL</div>
              <span class="rb-badge ${rc==='ok'?'rb-badge-green':'rb-badge-orange'}">${rc==='ok'?'Ideal':'A ajuster'}</span>
            </div>
            <div class="rb-progress ${rc}"><span style="width:${Math.min(100,ppu/120*100)}%"></span></div>
            <div style="font-size:1rem;font-weight:700;margin-top:6px;">${ppu.toFixed(0)} g/UFL</div>
          </div>
        </div>
        <div class="rb-panel" style="margin-top:16px;">
          <h4>Detail</h4>
          <table class="rb-table">
            <thead><tr><th>Aliment</th><th>kg MS</th><th>UFL</th><th>PDI (g)</th></tr></thead>
            <tbody>
              ${a.items.map(i=>`<tr><td>${i.nom}</td><td>${i.qty.toFixed(1)}</td><td>${i.ufl.toFixed(3)}</td><td>${i.pdi.toFixed(0)}</td></tr>`).join('')}
              <tr style="font-weight:700;background:var(--bg);"><td>TOTAL</td><td>${a.totalMS.toFixed(1)}</td><td>${a.totalUFL.toFixed(2)}</td><td>${a.totalPDI.toFixed(0)}</td></tr>
            </tbody>
          </table>
        </div>`;
      cont.classList.remove('hidden');
    });

    // -- Bilan fourrager ----------------------------------
    function addStockLine() {
      const div = $('stock-lines'); if (!div) return;
      const row = document.createElement('div');
      row.className = 'rb-ration-row';
      row.style.gridTemplateColumns = '1fr 130px 110px 46px';
      row.innerHTML = `
        <input list="aliments-list" placeholder="Fourrage..." autocomplete="off">
        <input type="number" placeholder="t brutes" step="0.1" min="0">
        <input type="number" placeholder="% MS" step="1" min="0" max="100">
        <button type="button" onclick="this.closest('.rb-ration-row').remove()"
          style="background:var(--danger);color:#fff;border:none;border-radius:var(--r-sm);cursor:pointer;padding:6px 10px;font-weight:bold;">X</button>`;
      div.appendChild(row);
    }
    $('btn-add-stock')?.addEventListener('click', addStockLine);

    $('btn-calc-bilan-fourrager')?.addEventListener('click', () => {
      let stockTMS=0;
      document.querySelectorAll('#stock-lines .rb-ration-row').forEach(row => {
        const inp = row.querySelectorAll('input');
        stockTMS += (parseFloat(inp[1]?.value)||0) * ((parseFloat(inp[2]?.value)||0)/100);
      });
      const nbV   = parseFloat($('bf-nb-vaches')?.value)||0;
      const duree = parseFloat($('bf-duree')?.value)||0;
      const msJ   = parseFloat($('bf-ms-j')?.value)||0;
      const besoin = nbV*duree*msJ/1000;
      const solde  = stockTMS - besoin;
      const pct    = besoin>0 ? stockTMS/besoin*100 : 100;

      document.querySelector('[data-tab="bf-resultat"]')?.click();
      $('resultat-bilan-fourrager')?.classList.remove('hidden');

      if($('bf-stock-total'))  $('bf-stock-total').textContent  = stockTMS.toFixed(1);
      if($('bf-besoin-total')) $('bf-besoin-total').textContent = besoin.toFixed(1);
      if($('bf-bilan-value'))  $('bf-bilan-value').textContent  = (solde>=0?'+':'')+solde.toFixed(1);

      const msg = $('bf-status-msg');
      if (msg) {
        msg.textContent = solde>=0 ? 'Stocks suffisants' : 'Deficit de '+Math.abs(solde).toFixed(1)+' t MS';
        msg.className   = 'bf-status-msg '+(solde>=0?'positive':'negative');
      }
      const silo = $('bf-silo-stock');
      if (silo) { silo.style.height=Math.min(100,pct)+'%'; silo.className='bf-silo-fill '+(solde>=0?'positive':'negative'); }
      const sp = $('bf-silo-stock-pct'); if(sp) sp.textContent=pct.toFixed(0)+'%';

      const cowRow = $('bf-cow-row');
      if (cowRow&&nbV>0) {
        const n=Math.min(nbV,10), cov=Math.round(n*Math.min(1,pct/100));
        cowRow.innerHTML=Array.from({length:n},(_,i)=>`<span class="bf-cow${i<cov?' covered':''}">cow</span>`).join('');
      }
      const cb=$('bf-card-bilan'); if(cb) cb.className='bf-card '+(solde>=0?'positive':'negative');
    });

    // -- Profils ration -----------------------------------
    function updateRationProfiles() {
      const sel=$('ration-profiles'); if(!sel) return;
      const p=loadLS(LS.rationProfiles,{});
      sel.innerHTML='<option value="">-- Selectionner --</option>';
      Object.keys(p).forEach(n=>sel.innerHTML+=`<option value="${n}">${n}</option>`);
    }
    $('btn-save-ration-profile')?.addEventListener('click',()=>{
      const name=prompt('Nom du profil :'); if(!name?.trim()) return;
      const lines=[];
      document.querySelectorAll('#ration-lines .rb-ration-row').forEach(row=>{
        const inp=row.querySelectorAll('input');
        if(inp[0]?.value) lines.push({nom:inp[0].value,qty:inp[1]?.value||''});
      });
      const p=loadLS(LS.rationProfiles,{}); p[name.trim()]=lines;
      saveLS(LS.rationProfiles,p); updateRationProfiles();
      $('ration-profiles').value=name.trim();
    });
    $('btn-load-ration-profile')?.addEventListener('click',()=>{
      const name=$('ration-profiles')?.value; if(!name) return;
      const lines=loadLS(LS.rationProfiles,{})[name]; if(!lines) return;
      $('ration-lines').innerHTML='';
      lines.forEach(l=>{ addLine('ration-lines','aliments-list');
        const rows=document.querySelectorAll('#ration-lines .rb-ration-row');
        const last=rows[rows.length-1];
        if(last){last.querySelectorAll('input')[0].value=l.nom;last.querySelectorAll('input')[1].value=l.qty;}
      });
    });
    $('btn-delete-ration-profile')?.addEventListener('click',()=>{
      const name=$('ration-profiles')?.value; if(!name||!confirm('Supprimer "'+name+'" ?')) return;
      const p=loadLS(LS.rationProfiles,{}); delete p[name];
      saveLS(LS.rationProfiles,p); updateRationProfiles();
    });

    // -- Profils troupeau ---------------------------------
    function updateHerdProfiles() {
      const sel=$('herd-profiles'); if(!sel) return;
      const p=loadLS(LS.herdProfiles,{});
      sel.innerHTML='<option value="">-- Selectionner --</option>';
      Object.keys(p).forEach(n=>sel.innerHTML+=`<option value="${n}">${n}</option>`);
    }
    $('btn-save-herd-profile')?.addEventListener('click',()=>{
      const name=prompt('Nom du profil troupeau :'); if(!name?.trim()) return;
      const p=loadLS(LS.herdProfiles,{});
      p[name.trim()]={nbVaches:$('bf-nb-vaches')?.value,duree:$('bf-duree')?.value,msJour:$('bf-ms-j')?.value};
      saveLS(LS.herdProfiles,p); updateHerdProfiles(); $('herd-profiles').value=name.trim();
    });
    $('btn-load-herd-profile')?.addEventListener('click',()=>{
      const name=$('herd-profiles')?.value; if(!name) return;
      const p=loadLS(LS.herdProfiles,{})[name]; if(!p) return;
      if($('bf-nb-vaches')) $('bf-nb-vaches').value=p.nbVaches||'';
      if($('bf-duree'))     $('bf-duree').value=p.duree||'';
      if($('bf-ms-j'))      $('bf-ms-j').value=p.msJour||'';
    });
    $('btn-delete-herd-profile')?.addEventListener('click',()=>{
      const name=$('herd-profiles')?.value; if(!name||!confirm('Supprimer "'+name+'" ?')) return;
      const p=loadLS(LS.herdProfiles,{}); delete p[name];
      saveLS(LS.herdProfiles,p); updateHerdProfiles();
    });

    // -- Aliments personnalises ---------------------------
    function openCustomModal(idx) {
      editingFoodIndex = (idx !== undefined) ? idx : -1;
      const modal=$('custom-modal'); if(!modal) return;
      const h3=modal.querySelector('h3');
      if(editingFoodIndex>=0&&customFoodsDb[editingFoodIndex]){
        const a=customFoodsDb[editingFoodIndex];
        if(h3) h3.textContent='Modifier un aliment';
        if($('custom-nom')) $('custom-nom').value=a.nom||'';
        if($('custom-ms'))  $('custom-ms').value=a.msPct||'';
        if($('custom-ufl')) $('custom-ufl').value=a.uflPerKgMS||'';
        if($('custom-pdi')) $('custom-pdi').value=a.pdiPerKgMS||'';
        ['na','k','ca','mg','cl','s'].forEach(m=>{if($('custom-'+m))$('custom-'+m).value=a[m+'_gkgms']||'';});
        const btn=$('btn-add-custom'); if(btn) btn.textContent='Enregistrer';
      } else {
        if(h3) h3.textContent='Ajouter un aliment';
        ['custom-nom','custom-ms','custom-ufl','custom-pdi','custom-na','custom-k','custom-ca','custom-mg','custom-cl','custom-s']
          .forEach(id=>{if($(id))$(id).value='';});
        const btn=$('btn-add-custom'); if(btn) btn.textContent='Ajouter';
      }
      modal.classList.remove('hidden');
    }
    $('btn-open-custom-modal')?.addEventListener('click',()=>openCustomModal());
    $('btn-open-custom-modal-ration')?.addEventListener('click',()=>openCustomModal());
    document.querySelectorAll('[data-modal-close]').forEach(el=>el.addEventListener('click',()=>$('custom-modal')?.classList.add('hidden')));

    $('btn-add-custom')?.addEventListener('click',()=>{
      const nom=$('custom-nom')?.value?.trim();
      const msPct=parseFloat($('custom-ms')?.value);
      const ufl=parseFloat($('custom-ufl')?.value);
      const pdi=parseFloat($('custom-pdi')?.value)||0;
      if(!nom||!msPct||!ufl){alert('Nom, % MS et UFL sont obligatoires.');return;}
      const item={nom,msPct,uflPerKgMS:ufl,pdiPerKgMS:pdi,
        na_gkgms:parseFloat($('custom-na')?.value)||undefined,
        k_gkgms: parseFloat($('custom-k')?.value) ||undefined,
        ca_gkgms:parseFloat($('custom-ca')?.value)||undefined,
        mg_gkgms:parseFloat($('custom-mg')?.value)||undefined,
        cl_gkgms:parseFloat($('custom-cl')?.value)||undefined,
        s_gkgms: parseFloat($('custom-s')?.value) ||undefined};
      if(editingFoodIndex>=0&&editingFoodIndex<customFoodsDb.length)
        customFoodsDb[editingFoodIndex]=item;
      else customFoodsDb.push(item);
      saveLS(LS.customFoods,customFoodsDb); hydrate();
      $('custom-modal')?.classList.add('hidden'); editingFoodIndex=-1;
      alert(nom+' sauvegarde');
    });
    $('btn-edit-custom-aliment')?.addEventListener('click',()=>{
      const idx=parseInt($('select-custom-aliment')?.value);
      if(isNaN(idx)){alert('Selectionnez un aliment.');return;} openCustomModal(idx);
    });
    $('btn-delete-custom-aliment')?.addEventListener('click',()=>{
      const idx=parseInt($('select-custom-aliment')?.value);
      if(isNaN(idx)||!confirm('Supprimer ?')) return;
      customFoodsDb.splice(idx,1); saveLS(LS.customFoods,customFoodsDb); hydrate();
    });
    ['custom-na','custom-k','custom-ca','custom-mg','custom-cl','custom-s'].forEach(id=>{
      $(id)?.addEventListener('input',()=>{
        const g=i=>Number($(i)?.value)||0;
        const baca=(g('custom-na')*43.5+g('custom-k')*25.6+g('custom-ca')*49.9+g('custom-mg')*82.2)
                  -(g('custom-cl')*28.2+g('custom-s')*62.4);
        const el=$('custom-baca-value');
        if(el){el.textContent=baca.toFixed(1);el.style.color=Math.abs(baca)>100?'var(--danger)':'var(--primary)';}
      });
    });

    // -- TMS ----------------------------------------------
    $('btn-calc-tms')?.addEventListener('click',()=>{
      const t=$('tms-type-silo')?.value;
      const L=parseFloat($('tms-longueur')?.value)||0, W=parseFloat($('tms-largeur')?.value)||0;
      const D=parseFloat($('tms-diametre')?.value)||0, H=parseFloat($('tms-hauteur')?.value)||0;
      const den=parseFloat($('tms-densite')?.value)||700, pMS=parseFloat($('tms-pourcent-ms')?.value)||35;
      const vol=t==='tower'?Math.PI*Math.pow((D||W)/2,2)*H:L*W*H;
      const tms=vol*den*(pMS/100)/1000;
      const el=$('resultat-tms');
      if(el){el.innerHTML='<h4>Resultat TMS</h4><p style="font-size:2rem;font-weight:800;color:var(--primary);margin:8px 0;">'+tms.toFixed(1)+' t MS</p><p>Volume : '+vol.toFixed(1)+' m3 | Densite : '+den+' kg/m3 | %MS : '+pMS+'%</p>';
        el.classList.remove('hidden');}
    });

    // -- INITIALISATION -----------------------------------
    alimentsDb    = parseAlimentsCsv(window.RB_ALIMENTS_CSV||'');
    customFoodsDb = loadLS(LS.customFoods,[]);
    costsByFeed   = loadLS(LS.costs,{});
    hydrate();
    goToStep(1);
    updateRationProfiles();
    updateHerdProfiles();
    addLine('ration-lines','aliments-list');
    addLine('ration-only-lines','aliments-list-ration-only');

      </script>


</body>
</html>
